{
    "manifest_version": 3,
    "name": "Shop Safe AI",
    "version": "1.0.0",
    "description": "Suporte à decisão baseado em IA para compras online",
    "icons": {
        "16": "./icon16.png",
        "48": "./icon48.png",
        "128": "./icon128.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>",
        "https://tcc-shop-safe.onrender.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "Shop Safe AI",
        "default_icon": {
            "16": "./icon16.png",
            "48": "./icon48.png",
            "128": "./icon128.png"
        }
    },
    "commands": {
        "toggle-panel": {
            "suggested_key": {
                "default": "Ctrl+Shift+S"
            },
            "description": "Toggle Shop Safe AI Panel"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "index.html",
                "content.js",
                "icon16.png",
                "icon48.png",
                "icon128.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}